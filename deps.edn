{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.4"}
        org.clojure/tools.cli {:mvn/version "1.4.256"}
        ;; MCP toolkit - pure Clojure MCP implementation
        fi.metosin/mcp-toolkit {:mvn/version "0.1.1-alpha"}
        ;; Utility libraries
        com.rpl/specter {:mvn/version "1.1.6"}
        org.clojure/data.json {:mvn/version "2.5.2"}
        pogonos/pogonos {:mvn/version "0.2.1"}
        ;; mcp-toolkit dependencies
        funcool/promesa {:mvn/version "12.0.777"}
        metosin/jsonista {:mvn/version "1.0.0"}
        http-kit/http-kit {:mvn/version "2.9.0-beta3"}
        metosin/reitit {:mvn/version "0.10.1"}

        ;; REPL and development dependencies
        nrepl/nrepl {:mvn/version "1.7.0"}
        cider/cider-nrepl {:mvn/version "0.59.0"}
        refactor-nrepl/refactor-nrepl {:mvn/version "3.13.0"}
        clj-kondo/clj-kondo {:mvn/version "2026.05.25"}
        rewrite-clj/rewrite-clj {:mvn/version "1.2.54"}
        dev.weavejester/cljfmt {:mvn/version "0.16.4"}
        ;; Performance analysis dependencies
        criterium/criterium {:mvn/version "0.4.6"}
        com.clojure-goes-fast/clj-async-profiler {:mvn/version "1.7.0"}

        ;; Logging
        com.taoensso/telemere {:mvn/version "1.2.1"}}
 :aliases
 {:repl-mcp {:main-opts ["-m" "is.simm.repl-mcp"]
             :extra-paths ["test"]
             :jvm-opts ["-Djdk.attach.allowAttachSelf"
                        "-XX:+UnlockDiagnosticVMOptions"
                        "-XX:+DebugNonSafepoints"
                        "-XX:+EnableDynamicAgentLoading"
                        "--enable-native-access=ALL-UNNAMED"]
             :extra-deps {org.slf4j/slf4j-api {:mvn/version "2.0.18"}
                          org.slf4j/slf4j-simple {:mvn/version "2.0.18"}}}
  ;; For invocations from the command line
  :dev {:extra-paths ["test"]
        :jvm-opts ["-Djdk.attach.allowAttachSelf"
                   "-XX:+UnlockDiagnosticVMOptions"
                   "-XX:+DebugNonSafepoints"
                   "-XX:+EnableDynamicAgentLoading"
                   "--enable-native-access=ALL-UNNAMED"]
        :extra-deps {org.slf4j/slf4j-api {:mvn/version "2.0.18"}
                     org.slf4j/slf4j-simple {:mvn/version "2.0.18"}}}
  :build {:deps {io.github.clojure/tools.build
                 {:mvn/version "0.10.13"}}
          :ns-default build}
  :test {:extra-paths ["test"]
         :jvm-opts ["-Djdk.attach.allowAttachSelf"
                    "-XX:+UnlockDiagnosticVMOptions"
                    "-XX:+DebugNonSafepoints"
                    "-XX:+EnableDynamicAgentLoading"
                    "--enable-native-access=ALL-UNNAMED"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}

                      org.slf4j/slf4j-nop {:mvn/version "2.0.18"}
                      org.babashka/http-client {:mvn/version "0.4.23"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
